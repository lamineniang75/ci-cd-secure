Thumbs.db
ehthumbs.db
Desktop.ini

# ============================================================================
# VARIABLES D'ENVIRONNEMENT
# ============================================================================
.env
.env.local
.env.*.local

# ============================================================================
# NOTES: BONNES PRATIQUES
# ============================================================================
# 1. JAMAIS committer :
#    - Mots de passe
#    - Clés API
#    - Tokens d'accès
#    - Fichiers .env
#    - Certificats privés
#
# 2. Utiliser GitHub Secrets pour l'environnement de build
#
# 3. Utiliser .env.example pour montrer la structure
#    .env.example:
#    DB_PASSWORD=change_me
#    API_KEY=change_me
#
# 4. Vérifier avant de committer
#    git diff --cached --name-only
#    grep -r "password\|api_key\|secret" --include="*.py"
#
# 5. Si secret committé accidentellement :
#    - Rotate la clé IMMÉDIATEMENT
#    - Utiliser git filter-branch pour l'historique
#    - Informer l'équipe sécurité

# ============================================================================
# FICHIERS À AJOUTER DANS .gitignore LOCALEMENT
# ============================================================================
# Pour ignorer temporairement:
# git update-index --skip-worktree <file>
# Pour arrêter d'ignorer:
# git update-index --no-skip-worktree <file>
