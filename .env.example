# ============================================================================
# FICHIER: .env.example
# DESCRIPTION: Template de variables d'environnement
# UTILISATION: cp .env.example .env (puis remplir les valeurs)
# ============================================================================

# ============================================================================
# APPLICATION
# ============================================================================
ENVIRONMENT=development          # development, staging, production
DEBUG=true
LOG_LEVEL=INFO

# ============================================================================
# BASE DE DONNÉES
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/app_db
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_NAME=app_database

# ============================================================================
# API EXTERNE & SERVICES
# ============================================================================
API_KEY=your_api_key_here
STRIPE_KEY=sk_test_xxxxxxxxxxxxxx
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1

# ============================================================================
# AUTHENTIFICATION & SECRETS
# ============================================================================
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_long
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
OAUTH_CLIENT_ID=your_oauth_client_id
OAUTH_CLIENT_SECRET=your_oauth_client_secret

# ============================================================================
# EMAIL & NOTIFICATIONS
# ============================================================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=noreply@example.com
NOTIFICATION_EMAIL=team@example.com

# ============================================================================
# CACHE & SESSIONS
# ============================================================================
REDIS_URL=redis://localhost:6379/0
SESSION_TIMEOUT=3600
CACHE_TTL=600

# ============================================================================
# SÉCURITÉ
# ============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
ALLOWED_HOSTS=localhost,127.0.0.1,example.com
SECRET_KEY=your_secret_key_for_csrf_tokens
SECURE_COOKIES=false              # true en production
HTTPS_ONLY=false                  # true en production

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
DATADOG_API_KEY=your_datadog_api_key
DATADOG_APP_KEY=your_datadog_app_key

# ============================================================================
# DÉVELOPPEMENT UNIQUEMENT
# ============================================================================
MOCK_EXTERNAL_APIS=false          # true pour tests
SEED_DATABASE=false               # true pour seed data initial
TEST_MODE=false                   # true pour tests

# ============================================================================
# NOTES IMPORTANTES
# ============================================================================
# 1. JAMAIS committer ce fichier rempli (secrets exposés!)
# 2. Copier .env.example en .env local et remplir les valeurs réelles
# 3. .env est dans .gitignore (ne sera jamais committé)
# 4. Pour production : utiliser des secrets manager (AWS Secrets, HashiCorp Vault, etc.)
# 5. Pour CI/CD : utiliser GitHub Secrets ou equivalent
# 6. Rotation régulière des secrets (API keys, DB passwords, etc.)
# 7. Logging des modifications de secrets pour audit trail

# ============================================================================
# CHARGEMENT DU FICHIER .ENV
# ============================================================================
# Python (avec python-dotenv):
#   from dotenv import load_dotenv
#   import os
#   
#   load_dotenv()
#   api_key = os.getenv("API_KEY")
#   
# Docker (.env file):
#   docker run --env-file .env myapp
#
# Docker Compose (docker-compose.yml):
#   env_file: .env
#   environment:
#     - DATABASE_URL=${DATABASE_URL}
